---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/oni-fanpage/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-oni-bg-deep text-oni-text-primary min-h-screen flex flex-col">
    <Navbar />
    <main class="max-w-6xl mx-auto px-4 py-8 flex-1 w-full">
      <slot />
    </main>
    <footer class="border-t border-oni-bg-elevated py-6 text-center text-oni-text-muted text-sm">
      ONI Reference &mdash; Fan-made quick reference
    </footer>
  </body>
</html>
