---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon } = Astro.props;
---

<a
  href={href}
  class="block bg-oni-bg-surface border border-oni-bg-elevated rounded-xl p-6 hover:border-oni-teal transition-colors group"
>
  {icon && <span class="block text-3xl mb-3">{icon}</span>}
  <h3 class="text-xl font-bold text-oni-text-primary group-hover:text-oni-teal transition-colors">
    {title}
  </h3>
  <p class="text-oni-text-secondary mt-2 text-sm">{description}</p>
  <span class="block mt-4 text-oni-text-muted group-hover:text-oni-teal transition-colors text-right text-lg">
    &rarr;
  </span>
</a>
