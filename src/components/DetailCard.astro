---
import StatPill from './StatPill.astro';

interface Props {
  entry: {
    data: {
      name: string;
      dlc: string[];
      diet: string[];
      output: { product: string; rate: { value: number; unit: string } };
      calories: { metabolism: { value: number; unit: string } };
      stable_capacity: number;
      temperature: {
        min: { value: number; unit: string };
        max: { value: number; unit: string };
      };
      grooming: {
        station: string;
        cycle_time: { value: number; unit: string };
      };
      notes?: string;
    };
  };
}

const { entry } = Astro.props;
const d = entry.data;

function formatName(slug: string): string {
  return slug
    .split('_')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

// Brief description based on output product
const brief = `${formatName(d.output.product)} Producer`;
---

<details class="group border border-oni-bg-elevated rounded-xl overflow-hidden open:border-oni-teal-dim">
  <summary class="cursor-pointer flex items-center justify-between p-4 hover:bg-oni-bg-surface/80 transition-colors select-none">
    <div class="flex items-center gap-3">
      <!-- Placeholder image -->
      <div class="w-12 h-12 rounded-lg bg-oni-bg-elevated flex items-center justify-center text-2xl shrink-0" aria-hidden="true">
        🥚
      </div>
      <div>
        <span class="font-bold text-oni-text-primary text-lg">{d.name}</span>
        <span class="text-oni-text-muted ml-2">&mdash; {brief}</span>
      </div>
    </div>
    <!-- Chevron indicator -->
    <svg class="w-5 h-5 text-oni-text-muted transition-transform group-open:rotate-180 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>

  <div class="p-4 pt-0 border-t border-oni-bg-elevated/50">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      <!-- Diet -->
      <div>
        <h4 class="text-xs text-oni-text-muted uppercase tracking-wider mb-2">Diet</h4>
        <div class="flex flex-wrap gap-1.5">
          {d.diet.map((item) => (
            <span class="inline-block text-xs px-2 py-1 rounded-md bg-oni-bg-elevated text-oni-text-secondary">
              {formatName(item)}
            </span>
          ))}
        </div>
      </div>

      <!-- Output -->
      <div>
        <h4 class="text-xs text-oni-text-muted uppercase tracking-wider mb-2">Output</h4>
        <p class="text-oni-text-secondary">
          {formatName(d.output.product)} at <StatPill value={d.output.rate.value} unit={d.output.rate.unit} />
        </p>
      </div>

      <!-- Metabolism -->
      <div>
        <h4 class="text-xs text-oni-text-muted uppercase tracking-wider mb-2">Metabolism</h4>
        <StatPill value={d.calories.metabolism.value.toLocaleString()} unit={d.calories.metabolism.unit} />
      </div>

      <!-- Temperature -->
      <div>
        <h4 class="text-xs text-oni-text-muted uppercase tracking-wider mb-2">Temperature Range</h4>
        <p class="flex items-center gap-1 text-oni-text-secondary">
          <StatPill value={d.temperature.min.value} unit={`\u00B0${d.temperature.min.unit}`} />
          <span class="text-oni-text-muted">to</span>
          <StatPill value={d.temperature.max.value} unit={`\u00B0${d.temperature.max.unit}`} />
        </p>
      </div>

      <!-- Stable Capacity -->
      <div>
        <h4 class="text-xs text-oni-text-muted uppercase tracking-wider mb-2">Stable Capacity</h4>
        <StatPill value={d.stable_capacity} unit="critters" />
      </div>

      <!-- Grooming -->
      <div>
        <h4 class="text-xs text-oni-text-muted uppercase tracking-wider mb-2">Grooming</h4>
        <p class="text-oni-text-secondary">
          {formatName(d.grooming.station)} &mdash; <StatPill value={d.grooming.cycle_time.value} unit={d.grooming.cycle_time.unit} />
        </p>
      </div>

      <!-- DLC -->
      <div>
        <h4 class="text-xs text-oni-text-muted uppercase tracking-wider mb-2">DLC Compatibility</h4>
        <div class="flex flex-wrap gap-1.5">
          {d.dlc.map((tag) => (
            <span class="inline-block text-xs px-2 py-1 rounded-full bg-oni-bg-elevated text-oni-text-muted">
              {formatName(tag)}
            </span>
          ))}
        </div>
      </div>
    </div>

    {d.notes && (
      <div class="mt-4 p-3 rounded-lg bg-oni-bg-elevated/50 border border-oni-bg-elevated">
        <p class="text-sm text-oni-text-secondary italic">{d.notes}</p>
      </div>
    )}
  </div>
</details>
