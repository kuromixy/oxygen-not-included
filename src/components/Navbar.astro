---
---

<nav class="bg-oni-bg-surface border-b border-oni-bg-elevated">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/oxygen-not-included/" class="text-oni-teal font-bold text-lg hover:text-oni-teal-dim transition-colors">
      ONI Reference
    </a>

    <div class="hidden md:flex items-center gap-6">
      <a href="/oxygen-not-included/ranching/" class="text-oni-text-secondary hover:text-oni-teal transition-colors">Ranching</a>
      <a href="/oxygen-not-included/farming/" class="text-oni-text-secondary hover:text-oni-teal transition-colors">Farming</a>
      <a href="/oxygen-not-included/power-plumbing/" class="text-oni-text-secondary hover:text-oni-teal transition-colors">Power/Plumbing</a>
      <a href="/oxygen-not-included/geysers-volcanoes/" class="text-oni-text-secondary hover:text-oni-teal transition-colors">Geysers</a>
      <a href="/oxygen-not-included/base-layouts/" class="text-oni-text-secondary hover:text-oni-teal transition-colors">Base Layouts</a>

      <div id="search-container" class="relative">
        <input
          id="search-input"
          type="text"
          placeholder="Search..."
          class="bg-oni-bg-elevated border border-oni-bg-elevated focus:border-oni-teal rounded px-3 py-1.5 text-sm text-oni-text-primary placeholder:text-oni-text-muted w-48 outline-none transition-colors"
          autocomplete="off"
        />
        <div
          id="search-dropdown"
          class="hidden absolute top-full mt-1 left-0 min-w-[280px] bg-oni-bg-surface border border-oni-bg-elevated rounded-lg shadow-lg overflow-y-auto max-h-[280px] z-50"
        ></div>
      </div>
    </div>

    <div class="flex items-center gap-1 md:hidden">
      <button
        id="search-toggle"
        class="md:hidden p-2 text-oni-text-secondary hover:text-oni-teal transition-colors"
        aria-label="Search"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
      </button>

      <button
        id="menu-toggle"
        class="md:hidden p-2 text-oni-text-secondary hover:text-oni-teal transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-search" class="hidden md:hidden border-t border-oni-bg-elevated px-4 py-3">
    <div id="mobile-search-container" class="relative">
      <input
        id="mobile-search-input"
        type="text"
        placeholder="Search..."
        class="w-full bg-oni-bg-elevated border border-oni-bg-elevated focus:border-oni-teal rounded px-3 py-2 text-sm text-oni-text-primary placeholder:text-oni-text-muted outline-none transition-colors"
        autocomplete="off"
      />
      <div
        id="mobile-search-dropdown"
        class="hidden absolute top-full mt-1 left-0 right-0 bg-oni-bg-surface border border-oni-bg-elevated rounded-lg shadow-lg overflow-y-auto max-h-[280px] z-50"
      ></div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-oni-bg-elevated px-4 py-3 space-y-2">
    <a href="/oxygen-not-included/ranching/" class="block text-oni-text-secondary hover:text-oni-teal transition-colors py-2">Ranching</a>
    <a href="/oxygen-not-included/farming/" class="block text-oni-text-secondary hover:text-oni-teal transition-colors py-2">Farming</a>
    <a href="/oxygen-not-included/power-plumbing/" class="block text-oni-text-secondary hover:text-oni-teal transition-colors py-2">Power/Plumbing</a>
    <a href="/oxygen-not-included/geysers-volcanoes/" class="block text-oni-text-secondary hover:text-oni-teal transition-colors py-2">Geysers</a>
    <a href="/oxygen-not-included/base-layouts/" class="block text-oni-text-secondary hover:text-oni-teal transition-colors py-2">Base Layouts</a>
  </div>
</nav>

<script is:inline>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>

<script>
  const BASE = import.meta.env.BASE_URL;
  let pagefind: any;

  async function loadPagefind() {
    if (!pagefind) {
      pagefind = await import(/* @vite-ignore */ `${BASE}pagefind/pagefind.js`);
      await pagefind.init();
    }
    return pagefind;
  }

  const desktopInput = document.getElementById('search-input') as HTMLInputElement;
  const mobileInput = document.getElementById('mobile-search-input') as HTMLInputElement;
  const desktopDropdown = document.getElementById('search-dropdown') as HTMLElement;
  const mobileDropdown = document.getElementById('mobile-search-dropdown') as HTMLElement;
  const searchContainer = document.getElementById('search-container');
  const mobileSearchContainer = document.getElementById('mobile-search-container');
  const searchToggle = document.getElementById('search-toggle');
  const mobileSearchDiv = document.getElementById('mobile-search');

  // Mobile search toggle
  searchToggle?.addEventListener('click', () => {
    mobileSearchDiv?.classList.toggle('hidden');
    if (!mobileSearchDiv?.classList.contains('hidden')) {
      mobileInput?.focus();
    }
  });

  function renderDropdown(results: any[], dropdown: HTMLElement) {
    if (results.length === 0) {
      dropdown.innerHTML = '<p class="p-3 text-oni-text-muted text-sm">No results found</p>';
    } else {
      dropdown.innerHTML = results.map((r: any) => `
        <a href="${r.url}" class="flex items-center justify-between gap-3 px-3 py-2 hover:bg-oni-bg-elevated transition-colors">
          <span class="text-oni-text-primary text-sm truncate">${r.meta.title}</span>
          ${r.meta.category ? `<span class="text-xs px-2 py-0.5 rounded bg-oni-teal/10 text-oni-teal whitespace-nowrap">${r.meta.category}</span>` : ''}
        </a>
      `).join('');
    }
    dropdown.classList.remove('hidden');
  }

  function setupSearch(input: HTMLInputElement, dropdown: HTMLElement) {
    let debounce: ReturnType<typeof setTimeout>;
    input.addEventListener('input', () => {
      const q = input.value.trim();
      clearTimeout(debounce);
      if (q.length < 3) {
        dropdown.innerHTML = '';
        dropdown.classList.add('hidden');
        return;
      }
      debounce = setTimeout(async () => {
        const pf = await loadPagefind();
        const result = await pf.debouncedSearch(q);
        if (!result) return;
        const top5 = await Promise.all(result.results.slice(0, 5).map((r: any) => r.data()));
        renderDropdown(top5, dropdown);
      }, 200);
    });
  }

  if (desktopInput && desktopDropdown) setupSearch(desktopInput, desktopDropdown);
  if (mobileInput && mobileDropdown) setupSearch(mobileInput, mobileDropdown);

  // Close on Escape (close dropdowns, keep query text)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      desktopDropdown?.classList.add('hidden');
      mobileDropdown?.classList.add('hidden');
    }
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    if (searchContainer && !searchContainer.contains(target)) {
      desktopDropdown?.classList.add('hidden');
    }
    if (mobileSearchContainer && !mobileSearchContainer.contains(target) && !(searchToggle?.contains(target))) {
      mobileDropdown?.classList.add('hidden');
    }
  });
</script>
