---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Power / Plumbing -- ONI Reference">
  <section class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-oni-text-primary">Power / Plumbing</h1>
    <p class="mt-3 text-oni-text-secondary text-lg">
      Generators, batteries, pipes, pumps -- wattage and throughput at a glance.
    </p>
  </section>

  <div class="flex items-center justify-center py-16">
    <div class="bg-oni-bg-surface border border-oni-bg-elevated rounded-xl p-8 text-center max-w-md">
      <p class="text-oni-text-muted text-lg">Coming in a future update</p>
      <p class="text-oni-text-muted text-sm mt-2">
        Power generation, battery capacity, pipe throughput, and pump stats will be added here.
      </p>
    </div>
  </div>
</BaseLayout>
