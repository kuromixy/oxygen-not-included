---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatPill from '../../components/StatPill.astro';
import { getCollection } from 'astro:content';

const batteries = await getCollection('batteries');

const generators = [
  { name: 'Coal Generator', href: '/oni-fanpage/power-plumbing/coal-generator/' },
  { name: 'Natural Gas Generator', href: '/oni-fanpage/power-plumbing/natural-gas-generator/' },
  { name: 'Hydrogen Generator', href: '/oni-fanpage/power-plumbing/hydrogen-generator/' },
  { name: 'Petroleum Generator', href: '/oni-fanpage/power-plumbing/petroleum-generator/' },
];

---

<BaseLayout title="Power / Plumbing -- ONI Reference">
  {/* Page heading */}
  <section class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-oni-text-primary">Power / Plumbing</h1>
    <p class="mt-3 text-oni-text-secondary text-lg">
      Generators and batteries -- wattage and throughput at a glance.
    </p>
  </section>

  {/* Generators section */}
  <section class="mb-10">
    <h2 class="text-xl font-bold text-oni-text-primary mb-4">Generators</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {generators.map((gen) => (
        <a
          href={gen.href}
          class="bg-oni-bg-surface border border-oni-bg-elevated rounded-lg p-4 hover:border-oni-teal transition-colors group"
        >
          <span class="text-lg font-semibold text-oni-text-primary group-hover:text-oni-teal transition-colors">
            {gen.name}
          </span>
        </a>
      ))}
    </div>
  </section>

  {/* Batteries section */}
  <section class="mb-10">
    <h2 class="text-xl font-bold text-oni-text-primary mb-4">Batteries</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {batteries.map((battery) => (
        <div class="bg-oni-bg-surface border border-oni-bg-elevated rounded-lg p-4">
          <h3 class="font-semibold text-oni-text-primary mb-3">{battery.data.name}</h3>
          <dl class="space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <dt class="text-oni-text-muted">Capacity</dt>
              <dd><StatPill value={battery.data.capacity.value} unit={battery.data.capacity.unit} /></dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-oni-text-muted">Leak Rate</dt>
              <dd><StatPill value={battery.data.leak_rate.value} unit={battery.data.leak_rate.unit} /></dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-oni-text-muted">Heat Output</dt>
              <dd><StatPill value={battery.data.heat_output.value} unit={battery.data.heat_output.unit} /></dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-oni-text-muted">Dimensions</dt>
              <dd class="text-oni-text-secondary">{battery.data.dimensions}</dd>
            </div>
          </dl>
          {battery.data.notes && (
            <p class="mt-3 text-xs text-oni-text-muted italic">{battery.data.notes}</p>
          )}
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
