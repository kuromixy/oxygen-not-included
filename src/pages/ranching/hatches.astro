---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import DetailCard from '../../components/DetailCard.astro';
import { getCollection } from 'astro:content';

const hatches = await getCollection('critters');
---

<BaseLayout title="Hatches -- ONI Reference">
  <!-- Breadcrumb -->
  <nav class="text-sm text-oni-text-muted mb-4" aria-label="Breadcrumb">
    <a href="/oni-fanpage/ranching/" class="hover:text-oni-teal transition-colors">Ranching</a>
    <span class="mx-1">&gt;</span>
    <span class="text-oni-text-secondary">Hatches</span>
  </nav>

  <!-- Page heading -->
  <section class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-oni-text-primary">Hatches</h1>
    <p class="mt-3 text-oni-text-secondary text-lg">
      The Hatch family of critters. They eat minerals and produce useful materials.
    </p>
  </section>

  <!-- Section 1: At a Glance -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-oni-text-primary mb-4">At a Glance</h2>
    <ComparisonTable entries={hatches} />
  </section>

  <!-- Section 2: Variant Details -->
  <section>
    <h2 class="text-xl font-bold text-oni-text-primary mb-4">Variant Details</h2>
    <div class="space-y-4">
      {hatches.map((hatch) => (
        <DetailCard entry={hatch} />
      ))}
    </div>
  </section>
</BaseLayout>
