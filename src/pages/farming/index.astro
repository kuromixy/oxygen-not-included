---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CropComparisonTable from '../../components/CropComparisonTable.astro';
import { getCollection } from 'astro:content';

const crops = await getCollection('crops');

function cropHref(id: string): string {
  return `/oxygen-not-included/farming/${id.replace(/_/g, '-')}/`;
}

const ORDER = ['mealwood', 'bristle_blossom', 'dusk_cap', 'pincha_pepper', 'sleet_wheat', 'waterweed', 'nosh_sprout'];
const sorted = [...crops].sort((a, b) => {
  const ai = ORDER.indexOf(a.data.id);
  const bi = ORDER.indexOf(b.data.id);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});
---

<BaseLayout title="Farming -- ONI Reference">
  {/* Page heading */}
  <section class="mb-8">
    <h1 data-pagefind-meta="category:Farming" class="text-3xl md:text-4xl font-bold text-oni-text-primary">Farming</h1>
    <p class="mt-3 text-oni-text-secondary text-lg">
      Crop temperatures, irrigation, growth times, and calorie yields.
    </p>
  </section>

  {/* Crop comparison table */}
  <section class="mb-10">
    <h2 class="text-xl font-bold text-oni-text-primary mb-4">Crop Comparison</h2>
    <CropComparisonTable crops={crops} />
  </section>

  {/* Individual crop links */}
  <section class="mb-10">
    <h2 class="text-xl font-bold text-oni-text-primary mb-4">Individual Crops</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {sorted.map((crop) => (
        <a
          href={cropHref(crop.data.id)}
          class="bg-oni-bg-surface border border-oni-bg-elevated rounded-lg p-4 hover:border-oni-teal transition-colors"
        >
          <div class="flex items-center justify-between">
            <span class="font-medium text-oni-text-primary">{crop.data.name}</span>
            {crop.data.dlc.includes('spaced_out') && (
              <span class="text-xs px-1.5 py-0.5 rounded bg-oni-bg-elevated text-oni-text-muted">DLC</span>
            )}
          </div>
          <p class="text-sm text-oni-text-muted mt-1">
            {crop.data.kcal_per_cycle.toLocaleString()} kcal/cycle &middot; {crop.data.growth_cycles} cycles
          </p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
