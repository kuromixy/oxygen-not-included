---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RanchBuildTabs from '../../components/RanchBuildTabs.astro';
import CropStatCard from '../../components/CropStatCard.astro';
import { getCollection } from 'astro:content';

const allCrops = await getCollection('crops');
const crop = allCrops.find(c => c.data.id === 'nosh_sprout');
---

<BaseLayout title="Nosh Sprout -- ONI Reference">
  {/* Breadcrumb */}
  <nav class="text-sm text-oni-text-muted mb-4" aria-label="Breadcrumb">
    <a href="/oni-fanpage/farming/" class="hover:text-oni-teal transition-colors">Farming</a>
    <span class="mx-1">&gt;</span>
    <span class="text-oni-text-secondary">Nosh Sprout</span>
  </nav>

  {/* Page heading */}
  <section class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-oni-text-primary">Nosh Sprout</h1>
    <p class="mt-3 text-oni-text-secondary text-lg">
      {crop?.data.notes}
    </p>
  </section>

  {/* Build layout tabs */}
  <RanchBuildTabs family="nosh-sprout" />

  {/* Stat card */}
  {crop && (
    <section class="mb-10">
      <h2 class="text-xl font-bold text-oni-text-primary mb-4">Crop Stats</h2>
      <CropStatCard entry={crop} />
    </section>
  )}
</BaseLayout>
