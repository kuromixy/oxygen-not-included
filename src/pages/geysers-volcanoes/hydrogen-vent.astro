---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RanchBuildTabs from '../../components/RanchBuildTabs.astro';
import BuildStatCard from '../../components/BuildStatCard.astro';
import { getCollection } from 'astro:content';

const allGeysers = await getCollection('geysers');
const geyser = allGeysers.find(g => g.data.id === 'hydrogen_vent');
---

<BaseLayout title="Hydrogen Vent -- ONI Reference">
  {/* Breadcrumb */}
  <nav class="text-sm text-oni-text-muted mb-4" aria-label="Breadcrumb">
    <a href="/oni-fanpage/geysers-volcanoes/" class="hover:text-oni-teal transition-colors">Geysers &amp; Volcanoes</a>
    <span class="mx-1">&gt;</span>
    <span class="text-oni-text-secondary">Hydrogen Vent</span>
  </nav>

  {/* Page heading */}
  <section class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-oni-text-primary">Hydrogen Vent</h1>
    {geyser && (
      <p class="mt-3 text-oni-text-secondary text-lg">{geyser.data.notes}</p>
    )}
  </section>

  {/* Build layout tabs */}
  <RanchBuildTabs family="hydrogen-vent" />

  {/* Stat card */}
  {geyser && (
    <section class="mb-10">
      <h2 class="text-xl font-bold text-oni-text-primary mb-4">Geyser Stats</h2>
      <BuildStatCard entry={geyser} mode="geyser" />
    </section>
  )}
</BaseLayout>
