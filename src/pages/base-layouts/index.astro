---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Base Layouts -- ONI Reference">
  <section class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-oni-text-primary">Base Layouts</h1>
    <p class="mt-3 text-oni-text-secondary text-lg">
      Room dimensions, required buildings, and optimal layouts for your colony.
    </p>
  </section>

  <div class="flex items-center justify-center py-16">
    <div class="bg-oni-bg-surface border border-oni-bg-elevated rounded-xl p-8 text-center max-w-md">
      <p class="text-oni-text-muted text-lg">Coming in a future update</p>
      <p class="text-oni-text-muted text-sm mt-2">
        Room size requirements, building placement guides, and layout templates will be added here.
      </p>
    </div>
  </div>
</BaseLayout>
