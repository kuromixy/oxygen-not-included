---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoomEntry from '../../components/RoomEntry.astro';
import { getCollection } from 'astro:content';

const allRooms = await getCollection('rooms');

// Define display order: upgrade chains first (grouped), then standalone rooms
const displayOrder = [
  // Latrine chain
  'latrine', 'washroom',
  // Barracks chain
  'barracks', 'luxury-barracks', 'private-bedroom',
  // Mess Hall chain
  'mess-hall', 'great-hall', 'banquet-hall',
  // Park chain
  'park', 'nature-reserve',
  // Standalone rooms
  'kitchen', 'massage-clinic', 'hospital', 'power-plant',
  'greenhouse', 'stable', 'laboratory', 'recreation-room',
];

const orderedRooms = displayOrder
  .map((id) => allRooms.find((r) => r.data.id === id))
  .filter(Boolean);

// Group labels for visual separation
const groups = [
  { label: 'Bathroom Chain', start: 0, end: 2 },
  { label: 'Bedroom Chain', start: 2, end: 5 },
  { label: 'Dining Chain', start: 5, end: 8 },
  { label: 'Nature Chain', start: 8, end: 10 },
  { label: 'Standalone Rooms', start: 10, end: 18 },
];
---

<BaseLayout title="Rooms Reference -- ONI Reference">
  <section class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-oni-text-primary">Rooms Reference</h1>
    <p class="mt-3 text-oni-text-secondary text-lg">
      Every standard room type the game recognizes, with dimensions, required buildings, bonuses, and layout tips.
    </p>
    <p class="mt-2 text-oni-text-muted text-sm">
      Rooms are grouped by upgrade chains. Click a group to expand it.
    </p>
  </section>

  {groups.map((group, i) => (
    <details class="mb-4 group" open={i === 0}>
      <summary class="cursor-pointer select-none list-none flex items-center gap-2 bg-oni-bg-surface border border-oni-bg-elevated rounded-lg px-4 py-3 hover:border-oni-teal transition-colors">
        <svg class="w-4 h-4 text-oni-text-muted transition-transform group-open:rotate-90 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-lg font-semibold text-oni-text-secondary">{group.label}</span>
        <span class="text-sm text-oni-text-muted ml-auto">{group.end - group.start} rooms</span>
      </summary>
      <div class="mt-2 ml-2 border-l-2 border-oni-bg-elevated pl-4">
        {orderedRooms.slice(group.start, group.end).map((room) => (
          <RoomEntry room={room} />
        ))}
      </div>
    </details>
  ))}
</BaseLayout>
